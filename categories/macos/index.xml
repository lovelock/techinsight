loading="lazy"
class="gallery-image"
data-flex-grow="127"
data-flex-basis="306px"
>&lt;/p>
&lt;p>点击一下就变成这样&lt;/p>
&lt;p>&lt;img src="https://techinsight.pages.dev/p/%E5%85%B3%E6%8E%89iterm%E4%B8%80%E4%B8%AA%E9%9D%9E%E5%B8%B8%E6%81%BC%E4%BA%BA%E7%9A%84%E5%8A%9F%E8%83%BD/on-click.png"
